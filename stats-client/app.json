[
  {
    "name"              : "vana-stats-client",
    "script"            : "node.js",
    "log_date_format"   : "YYYY-MM-DD HH:mm Z",
    "merge_logs"        : false,
    "watch"             : false,
    "max_restarts"      : 10,
    "exec_interpreter"  : "node",
    "exec_mode"         : "fork_mode",
    "env":
    {
      "NODE_ENV"        : "production",
      "RPC_PORT"        : "8545",
      "LISTENING_PORT"  : "30303",
      "VERBOSITY"       : 2
    }
  }
]
